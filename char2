#include <stdio.h>
int increment(int x) //这里吧原来的void 改正了int 类型，因此有了返回值
{
	return x += 1;  /*这里的x += 1等价于 x = x + 1 ，*/
                    /* int函数要有返回值这里加入return */              
}

int main(void)
{
	int i = 1, j = 2;
	int a,b;
    a = increment(i);
    b = increment(j);
    printf("%d,%d",a,b); //加入打印内容进行测试
    return 0;
}
